<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <!-- Facebook OG Image - 1200x630px -->
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e40af;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="logoGlossy" cx="35%" cy="35%">
      <stop offset="0%" style="stop-color:#7c9ad9;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#5273b8;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1e40af;stop-opacity:1" />
    </radialGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bgGradient)"/>
  
  <!-- Decorative circles -->
  <circle cx="100" cy="100" r="80" fill="#FFFFFF" opacity="0.05"/>
  <circle cx="1100" cy="530" r="100" fill="#FFFFFF" opacity="0.05"/>
  
  <!-- Logo Circle (left side) -->
  <circle cx="280" cy="315" r="180" fill="url(#logoGlossy)"/>
  
  <!-- Text on logo -->
  <text x="280" y="305" font-family="Arial, sans-serif" font-size="42" font-weight="bold" fill="#FFFFFF" text-anchor="middle" letter-spacing="2">SCHENGEN</text>
  <text x="280" y="345" font-family="Arial, sans-serif" font-size="30" font-weight="600" fill="#FFD700" text-anchor="middle" letter-spacing="1">Visa Support</text>
  
  <!-- Main heading (right side) -->
  <text x="520" y="250" font-family="Arial, sans-serif" font-size="52" font-weight="bold" fill="#FFFFFF" text-anchor="start">Your Complete Guide</text>
  <text x="520" y="310" font-family="Arial, sans-serif" font-size="52" font-weight="bold" fill="#FFFFFF" text-anchor="start">to Schengen Visas</text>
  
  <!-- Subheading -->
  <text x="520" y="370" font-family="Arial, sans-serif" font-size="28" fill="#FFFFFF" opacity="0.9" text-anchor="start">Expert help • Free templates</text>
  <text x="520" y="410" font-family="Arial, sans-serif" font-size="28" fill="#FFFFFF" opacity="0.9" text-anchor="start">Step-by-step guides • 2026</text>
  
  <!-- Airplane emoji/icon -->
  <text x="1050" y="250" font-size="80">✈️</text>
</svg>
